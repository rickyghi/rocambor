{
  "name": "rocambor-server",
  "version": "2.0.0",
  "private": true,
  "type": "commonjs",
  "main": "dist/server/src/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "npm run clean && tsc -p tsconfig.json",
    "start": "node --enable-source-maps dist/server/src/server.js",
    "clean": "rimraf dist",
    "migrate": "node dist/server/scripts/migrate.js",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "ioredis": "^5.3.2",
    "jose": "^6.2.1",
    "pg": "^8.12.0",
    "ws": "^8.18.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.5.0",
    "@types/pg": "^8.6.6",
    "@types/ws": "^8.5.10",
    "rimraf": "^5.0.7",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.6.2",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
